rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /skills/{skillId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.creatorUserId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.creatorUserId == request.auth.uid;
    }

    match /skillRequests/{requestId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /userProfiles/{uid} {
      allow read, create, update, delete: if ownsUserDocument(uid);
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /skillAvailability/{skillId} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
